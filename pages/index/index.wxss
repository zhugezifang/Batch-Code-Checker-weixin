.index-page {
  min-height: 100vh;
  padding: 0 0 56rpx;
  background: #eef1f8;
}

.notice-bar {
  display: flex;
  align-items: center;
  gap: 18rpx;
  height: 70rpx;
  box-sizing: border-box;
  padding: 0 28rpx;
  background: #e9f8ff;
}

.notice-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 28rpx;
  height: 28rpx;
  border: 3rpx solid #1e90ff;
  border-radius: 50%;
  color: #1e90ff;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 28rpx;
}

.notice-text {
  color: #1685ff;
  font-size: 30rpx;
  font-weight: 700;
}

.query-area {
  position: relative;
  padding: 40rpx 32rpx 0;
}

.brand-section {
  position: relative;
  z-index: 100;
}

.form-row {
  display: flex;
  align-items: center;
  width: 100%;
  height: 128rpx;
  box-sizing: border-box;
  margin-bottom: 40rpx;
  padding: 0 42rpx 0 54rpx;
  border-radius: 64rpx;
  background: #ffffff;
}

.row-label {
  flex: 0 0 112rpx;
  color: #606266;
  font-size: 30rpx;
  font-weight: 800;
}

.brand-input,
.input-field {
  flex: 1;
  height: 96rpx;
  min-width: 0;
  color: #303133;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 96rpx;
}

.input-placeholder {
  color: #8d9099;
  font-weight: 700;
}

.row-arrow {
  flex: 0 0 auto;
  margin-left: 16rpx;
  color: #909399;
  font-size: 58rpx;
  font-weight: 300;
  line-height: 1;
}

.brand-list {
  position: absolute;
  top: 136rpx;
  right: 0;
  left: 0;
  z-index: 101;
  max-height: 500rpx;
  overflow: auto;
  border: 1rpx solid #e7eaf1;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 24rpx 54rpx rgba(28, 36, 56, 0.16);
}

.is-under-dropdown {
  position: relative;
  z-index: 1;
}

.brand-option,
.brand-empty {
  display: flex;
  align-items: center;
  min-height: 90rpx;
  box-sizing: border-box;
  padding: 0 44rpx;
  border-bottom: 1rpx solid #f0f2f7;
  color: #42464f;
  font-size: 28rpx;
  font-weight: 650;
}

.brand-option:last-child {
  border-bottom: 0;
}

.brand-option.is-selected {
  background: #f3edff;
  color: #7434e8;
}

.brand-empty {
  justify-content: center;
  color: #9ca3af;
}

.helper-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 8rpx 72rpx 40rpx;
}

.helper {
  font-size: 30rpx;
  font-weight: 700;
}

.muted-helper {
  color: #909399;
}

.primary-helper {
  color: #2f97ff;
}

.query-button {
  width: 100%;
  height: 96rpx;
  box-sizing: border-box;
  padding: 0;
  border: 0;
  border-radius: 48rpx;
  background: #7434e8;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 96rpx;
}

.query-button::after {
  border: 0;
}

.query-button:active {
  opacity: 0.9;
}

.record-title {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  margin-top: 56rpx;
  color: #999ca3;
}

.record-line,
.record-text {
  font-size: 30rpx;
  font-weight: 800;
}

.result-panel {
  margin: 34rpx 32rpx 0;
  overflow: hidden;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 44rpx rgba(28, 36, 56, 0.08);
}

.result-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 30rpx 32rpx;
  background: linear-gradient(135deg, #effaf3 0%, #f7fffb 100%);
}

.is-fail .result-hero {
  background: linear-gradient(135deg, #fff1f2 0%, #fff8f8 100%);
}

.result-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 64rpx;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #18a058;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 900;
}

.result-main {
  flex: 1;
  min-width: 0;
}

.is-fail .result-icon {
  background: #d03050;
}

.result-kicker,
.result-title,
.result-code-pill,
.metric-label,
.metric-value,
.date-year,
.date-month,
.advice-title {
  display: block;
}

.result-kicker {
  margin-bottom: 8rpx;
  color: #909399;
  font-size: 24rpx;
  font-weight: 700;
}

.result-title {
  color: #303133;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.35;
}

.result-code-pill {
  display: inline-block;
  max-width: 100%;
  box-sizing: border-box;
  overflow: hidden;
  margin-top: 12rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.8);
  color: #606266;
  font-family: Menlo, Monaco, Consolas, monospace;
  font-size: 24rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.result-status {
  flex: 0 0 auto;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #e8f8ee;
  color: #18a058;
  font-size: 24rpx;
  font-weight: 800;
}

.is-fail .result-status {
  background: #feeceb;
  color: #d03050;
}

.result-metrics {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  padding: 26rpx 28rpx 10rpx;
}

.metric-card {
  min-height: 142rpx;
  box-sizing: border-box;
  padding: 24rpx 22rpx;
  border-radius: 22rpx;
  background: #f7f8fc;
}

.metric-label {
  color: #909399;
  font-size: 24rpx;
  font-weight: 700;
}

.metric-value {
  margin-top: 16rpx;
  color: #303133;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.25;
  word-break: break-all;
}

.date-metric {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-top: 12rpx;
}

.date-year {
  color: #303133;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.15;
}

.date-month {
  color: #606266;
  font-size: 28rpx;
  font-weight: 800;
}

.is-pass .metric-card:first-child {
  background: #f0fdf4;
}

.is-pass .metric-card:first-child .metric-value,
.is-pass .date-year {
  color: #18a058;
}

.is-fail .metric-card:first-child {
  background: #fff1f2;
}

.is-fail .metric-card:first-child .metric-value,
.is-fail .date-year {
  color: #d03050;
}

.result-info {
  margin: 16rpx 28rpx 0;
  padding: 4rpx 0;
  border-radius: 20rpx;
  background: #fbfcff;
}

.result-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 18rpx 22rpx;
  border-bottom: 1rpx solid #f0f2f7;
}

.result-row:last-child {
  border-bottom: 0;
}

.result-label {
  flex: 0 0 148rpx;
  color: #909399;
  font-size: 26rpx;
}

.result-value {
  min-width: 0;
  color: #303133;
  font-size: 26rpx;
  font-weight: 700;
  text-align: right;
  word-break: break-all;
}

.code-value {
  font-family: Menlo, Monaco, Consolas, monospace;
  letter-spacing: 1rpx;
}

.result-advice {
  margin: 22rpx 28rpx 28rpx;
  padding: 22rpx 24rpx;
  border-radius: 18rpx;
  background: #f6f7fb;
  color: #606266;
  font-size: 26rpx;
  font-weight: 650;
  line-height: 1.6;
}

.advice-title {
  margin-bottom: 8rpx;
  font-size: 27rpx;
  font-weight: 900;
}

.is-pass .result-advice {
  background: #f0fdf4;
  color: #167548;
}

.is-fail .result-advice {
  background: #fff1f2;
  color: #b42318;
}
