<view class="page result-page">
  <view class="summary section">
    <view class="summary-main">
      <text class="summary-title">检测结果</text>
      <text class="summary-subtitle">共 {{summary.total}} 条，{{summary.pass}} 条通过，{{summary.fail}} 条异常</text>
    </view>
    <button class="copy-button" bindtap="copyFailed">复制异常</button>
  </view>

  <view class="result-list">
    <view wx:if="{{!results.length}}" class="empty panel">
      <text class="empty-title">暂无检测结果</text>
      <text class="muted">返回首页输入码值后开始检测。</text>
    </view>

    <view wx:for="{{results}}" wx:key="id" class="result-item {{item.status === 'pass' ? 'is-pass' : 'is-fail'}}">
      <view class="result-info">
        <text class="code">{{item.code}}</text>
        <text class="message">{{item.message}}</text>
      </view>
      <text class="status">{{item.status === 'pass' ? '通过' : '异常'}}</text>
    </view>
  </view>
</view>
